{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://socioslinux.org/schemas/nlboot/boot-evidence.schema.json",
  "title": "Boot Evidence Receipt Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "boot_evidence_id",
    "service_id",
    "node_id",
    "boot_release_set",
    "measurement_refs",
    "ledger_binding"
  ],
  "properties": {
    "boot_evidence_id": {
      "type": "string",
      "pattern": "^boot-evidence\\.[a-z0-9][a-z0-9.-]*$"
    },
    "service_id": {
      "type": "string",
      "const": "svc.managed.boot-evidence"
    },
    "node_id": {
      "type": "string",
      "minLength": 1
    },
    "boot_release_set": {
      "type": "string",
      "minLength": 1
    },
    "measurement_refs": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string"}
    },
    "ledger_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_service_id", "evidence_ledger_ref"],
      "properties": {
        "target_service_id": {"type": "string", "const": "svc.platform.evidence-ledger"},
        "evidence_ledger_ref": {"type": "string", "minLength": 1}
      }
    },
    "validation_status": {
      "type": "string",
      "enum": ["pending", "valid", "invalid", "revoked"],
      "default": "pending"
    }
  }
}
